    <!--分页查询订单-->
    <select id="findPage" resultMap="OrderResultMap">
        select *, u.nickname
        from `order` o
        left join user u on o.user_id = u.id
        <where>
            <if test="orderNo != null and orderNo != ''">
                and o.order_no like concat('%', #{orderNo} ,'%')
            </if>
            <if test="userId != null">
                and o.user_id = #{userId}
            </if>
            <if test="status != null">
                and o.status = #{status}
            </if>
        </where>
        order by o.create_time desc
    </select>
    <!--查询订单总数-->
    <select id="count" resultType="java.lang.Integer">
        select count(*) from `order` o
        <where>
            <if test="orderNo != null and orderNo != ''">
                and o.order_no like concat('%', #{orderNo} ,'%')
            </if>
            <if test="userId != null">
                and o.user_id = #{userId}
            </if>
            <if test="status != null">
                and o.status = #{status}
            </if>
        </where>
    </select>

    <!--插入订单-->
    <insert id="insert" parameterType="com.example.demo.domian.Order" useGeneratedKeys="true" keyProperty="id">
        insert into `order`(order_no, user_id, total_amount, status, receiver_name, receiver_phone, receiver_address,create_time, update_time)
        values(#{orderNo}, #{userId}, #{totalAmount}, #{status}, #{receiverName}, #{receiverPhone}, #{receiverAddress}, #{createTime},#{updateTime})
    </insert>

    <!--更新订单-->
    <update id="update" parameterType="com.example.demo.domian.Order">
        <!-- 修复点1：给表 `order` 定义别名 o，与字段中的 o. 对应 -->
        update `order` o
        <set>
            <!-- 修复点2：删除所有 if 标签内的末尾逗号，由 <set> 自动处理 -->
            <if test="orderNo != null and orderNo != ''">
                o.order_no = #{orderNo}
            </if>
            <if test="userId != null">
                o.user_id = #{userId}
            </if>
            <if test="totalAmount != null">
                o.total_amount = #{totalAmount}
            </if>
            <if test="status != null">
                o.status = #{status}
            </if>
            <if test="receiverName != null">
                o.receiver_name = #{receiverName}
            </if>
            <if test="receiverPhone != null">
                o.receiver_phone = #{receiverPhone}
            </if>
            <if test="receiverAddress != null">
                o.receiver_address = #{receiverAddress}
            </if>
        </set>
        where o.id = #{id} <!-- 优化：where 条件也用别名 o.id，保持一致性 -->
    </update>
    <!--删除订单-->
    <delete id="deleteById" parameterType="long">
        delete from `order`
        where id = #{id}
    </delete>

    <!--根据订单ID查询订单项-->
    <select id="findOrderItemsByOrderId" parameterType="long" resultMap="OrderItemResultMap">
        select *
        from order_item
        where order_id = #{orderId}
    </select>
    <!--批量插入订单项-->
    <insert id="insertOrderItems" parameterType="java.util.List">
        insert into order_item(order_id, product_id, product_name, price, quantity, subtotal, create_time, update_time)
        values
        <foreach collection="list" item="item" separator=",">
            (#{item.orderId}, #{item.productId}, #{item.productName}, #{item.price}, #{item.quantity}, #{item.subtotal}, #{item.createTime}, #{item.updateTime})
        </foreach>
    </insert>
    <!--根据订单ID删除订单项-->
    <delete id="deleteOrderItemsByOrderId" parameterType="long">
        delete
        from order_item
        where order_id = #{orderId};
    </delete>

</mapper>