<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.OrderMapper">

    <!--订单结果映射  前面对应实体类，后面对应数据库-->
    <resultMap id="OrderResultMap" type="com.example.demo.domian.Order">
        <id property="id" column="id"/>
        <id property="orderNo" column="order_no"/>
        <id property="userId" column="user_id"/>
        <id property="totalAmount" column="total_amount"/>
        <id property="status" column="status"/>
        <id property="receiverName" column="receiver_name"/>
        <id property="receiverPhone" column="receiver_phone"/>
        <id property="receiverAddress" column="receiver_address"/>
        <id property="createTime" column="create_time"/>
        <id property="updateTime" column="update_time"/>
    </resultMap>
    <!--订单项结果映射  前面对应实体类，后面对应数据库-->
    <resultMap id="OrderItemResultMap" type="com.example.demo.domian.OrderItem">
        <id property="id" column="id"/>
        <id property="orderId" column="order_id"/>
        <id property="productId" column="product_id"/>
        <id property="productName" column="product_name"/>
        <id property="price" column="price"/>
        <id property="quantity" column="quantity"/>
        <id property="subtotal" column="subtotal"/>
        <id property="createTime" column="create_time"/>
        <id property="updateTime" column="update_time"/>
    </resultMap>
    <!--查询所有订单-->
    <select id="findAll"  resultMap="OrderResultMap">
        select *
        from `order`
        order by create_time desc
    </select>
    <!--ID查询订单-->
    <select id="findById" resultMap="OrderResultMap">
        select *
        from `order`
        where id = #{id}
    </select>
    <!--根据商品ID查询商品信息-->
    <select id="findByOrderNo" resultMap="OrderResultMap">
        select *
        from `order`
        where order_no = #{orderNo}
    </select>
    <!--根据根据用户ID查询订单-->
        <select id="findByUserId" parameterType="long" resultMap="OrderResultMap">
        select *
        from `order`
        where user_id = #{userId}
    </select>
