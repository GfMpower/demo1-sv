<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.CategoryMapper">

    <!--结果映射  前面对应实体类，后面对应数据库-->
    <resultMap id="CategoryResultMap" type="com.example.demo.domian.Category">
        <id property="id" column="id"/>
        <id property="name" column="name"/>
        <id property="parentId" column="parent_id"/>
        <id property="level" column="level"/>
        <id property="sort" column="sort"/>
        <id property="description" column="description"/>
        <id property="status" column="status"/>
        <id property="createTime" column="create_time"/>
        <id property="updateTime" column="update_time"/>
        <id property="icon" column="icon"/>
    </resultMap>

    <!--查询分类列表-->
    <select id="findAll"  resultMap="CategoryResultMap">
        select *
        from category
        order by sort
    </select>
    <!--根据分类ID查询用户信息-->
    <select id="findById" resultMap="CategoryResultMap">
        select *
        from category
        where id = #{id}
    </select>
    <!--根据父ID查询用户信息-->
    <select id="findByParentId" parameterType="long" resultMap="CategoryResultMap">
        select *
        from category
        where parent_id = #{parentId}
        order by sort
    </select>
    <!--查询顶级分类-->
    <select id="findTopCategory" resultMap="CategoryResultMap">
        select *
        from category
        where parent_id = 0 and status = 1
        order by sort
    </select>
    <!--插入分类-->
    <insert id="insert" parameterType="com.example.demo.domian.Category" useGeneratedKeys="true" keyProperty="id">
        insert into category(name, parent_id, level, sort, icon, description, status)
        values(#{name}, #{parentId}, #{level}, #{sort}, #{icon}, #{description}, #{status})
    </insert>
    <!--更新分类-->
    <update id="update" parameterType="com.example.demo.domian.Category" useGeneratedKeys="true">
        update category
        <set>
            <if test="name != null and name != ''">
                name = #{name},
            </if>
            <if test="parentId != null and parentId != ''">
                parent_id = #{parentId},
            </if>
            <if test="level != null">
                level = #{level},
            </if>
            <if test="sort != null">
                sort = #{sort},
            </if>
            <if test="icon != null and icon != ''">
                icon = #{icon},
            </if>
            <if test="description != null and description != ''">
                description = #{description},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
        </set>
        where id = #{id}
    </update>
    <!--删除用户-->
    <delete id="deleteById" parameterType="long">
        delete from category
        where id = #{id}
    </delete>
</mapper>